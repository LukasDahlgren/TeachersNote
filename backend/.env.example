# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=teachersnote

# Auth
JWT_SECRET_KEY=your-secret-key-here-change-this-in-production
ADMIN_SECRET=your-admin-secret-here

# API Keys
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173

# Enrichment settings
ENRICH_MAX_WORKERS=4
ENRICH_MAX_TRANSCRIPT_WORDS=500
ENRICH_MAX_OUTPUT_TOKENS=900
ENRICH_MAX_ATTEMPTS=4
ENRICH_LOG_USAGE=true
ENRICH_PROVIDER=anthropic
# ENRICH_MODEL=claude-haiku-4-5

# Transcription settings
# TRANSCRIBE_MAX_UPLOAD_BYTES=24000000
# TRANSCRIBE_CHUNK_HEADROOM_PCT=90
# TRANSCRIBE_MIN_CHUNK_SECONDS=300
# TRANSCRIBE_PARALLEL_WORKERS=2
# TRANSCRIBE_GLOBAL_MAX_CONCURRENT=4
# TRANSCRIBE_PARALLEL_MIN_CHUNKS=2

# Alignment settings
# ALIGN_MODEL=sonnet  # Allowed values: sonnet, haiku
# ALIGN_MAX_TRANSCRIPT_SEGMENTS=900
# ALIGN_MAX_SEGMENT_CHARS=180
# ALIGN_MAX_SLIDE_CHARS=1200

# Feature flags
# DISABLE_EXTERNAL_AI=false

# Remote media settings
# REMOTE_MEDIA_ALLOWED_EXTENSIONS=.mp4,.mov,.webm,.wav,.m4a,.mp3
# REMOTE_MEDIA_MAX_BYTES=524288000
# REMOTE_MEDIA_CONNECT_TIMEOUT_SEC=10
# REMOTE_MEDIA_READ_TIMEOUT_SEC=120
# REMOTE_MEDIA_TOTAL_TIMEOUT_SEC=600

# Job TTL settings
# REGENERATE_NOTES_JOB_TTL_SECONDS=1800
# PROCESS_UPLOAD_JOB_TTL_SECONDS=1800
